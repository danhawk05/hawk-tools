<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="robots" content="noindex, nofollow" />
<title>Internal Link Reallocator — Hawk Marketing</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
  :root{
    --bg:#F5F2EA; --paper:#FFFFFF; --ink:#1C1B19; --muted:#6B6557; --faint:#9A9384;
    --line:#E5E0D3; --accent:#C8472B; --accentSoft:#FBEAE4; --forest:#2F5D50; --forestSoft:#E6EFEB; --amber:#B45309; --amberSoft:#FBF0DD;
  }
  *{box-sizing:border-box}
  body{margin:0;background:var(--bg);color:var(--ink);font-family:'IBM Plex Sans',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;line-height:1.6}
  .wrap{max-width:1000px;margin:0 auto;padding:32px 22px 64px}
  h1{font-family:'Fraunces',Georgia,serif;font-size:32px;font-weight:600;letter-spacing:-.01em;margin:0}
  .mono{font-family:'IBM Plex Mono',ui-monospace,monospace}
  .serif{font-family:'Fraunces',Georgia,serif}
  .tag{font-size:11px;color:var(--forest);border:1px solid var(--forest);border-radius:5px;padding:2px 7px}
  .lead{color:var(--muted);font-size:14.5px;max-width:700px;margin:8px 0 18px}
  .proxy{background:var(--amberSoft);color:var(--amber);border-radius:8px;padding:10px 14px;font-size:12.5px;max-width:700px;margin-bottom:22px;line-height:1.5}
  .drop{background:var(--paper);border:1.5px dashed var(--line);border-radius:12px;padding:28px;text-align:center;cursor:pointer;transition:.15s}
  .drop:hover{border-color:var(--accent)}
  .drop.drag{background:var(--accentSoft);border-color:var(--accent)}
  .card{background:var(--paper);border:1px solid var(--line);border-radius:12px}
  .controls{padding:18px;margin-top:16px;display:none}
  .grid4{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;align-items:end}
  label.f{font-size:10.5px;letter-spacing:.07em;text-transform:uppercase;color:var(--muted);font-weight:600;display:block;margin-bottom:5px}
  input{width:100%;padding:8px 10px;border:1px solid var(--line);border-radius:7px;font-size:13.5px;background:var(--paper);color:var(--ink);font-family:inherit}
  input:focus{outline:none;border-color:var(--accent)}
  .stats{display:none;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:16px}
  .stat{background:var(--paper);border:1px solid var(--line);border-radius:12px;padding:16px 18px}
  .stat .l{font-size:10.5px;letter-spacing:.07em;text-transform:uppercase;color:var(--muted);font-weight:600}
  .stat .v{font-family:'Fraunces',Georgia,serif;font-size:30px;font-weight:600;line-height:1.15;margin-top:3px}
  .stat .s{font-size:11.5px;color:var(--muted);margin-top:2px}
  .results{margin-top:16px;display:none}
  .rhead{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;flex-wrap:wrap;gap:10px}
  button.exp{background:var(--ink);color:#fff;border:none;border-radius:7px;padding:7px 14px;font-size:12.5px;font-weight:600;cursor:pointer;font-family:inherit}
  button.exp:hover{opacity:.9}
  .pair{background:var(--paper);border:1px solid var(--line);border-radius:10px;padding:14px 16px;margin-bottom:10px;display:grid;grid-template-columns:1fr auto 1fr;gap:14px;align-items:center}
  .node .lab{font-size:10px;letter-spacing:.07em;text-transform:uppercase;font-weight:700;margin-bottom:3px}
  .node.donor .lab{color:var(--forest)}
  .node.target .lab{color:var(--accent)}
  .node .url{font-size:13.5px;font-weight:500;word-break:break-word;line-height:1.35}
  .node .meta{font-size:11.5px;color:var(--muted);margin-top:3px;font-variant-numeric:tabular-nums}
  .arrow{text-align:center;color:var(--muted)}
  .arrow .big{font-size:20px;line-height:1}
  .arrow .topic{font-size:10.5px;color:var(--faint);margin-top:2px;max-width:120px}
  .arrow .topic b{color:var(--ink);font-weight:600}
  .note{font-size:12px;color:var(--faint);margin-top:14px;line-height:1.55;display:none}
  .err{margin-top:12px;padding:10px 13px;background:var(--accentSoft);border-radius:8px;font-size:13px;color:#7a2a18;display:none}
  footer{margin-top:36px;padding-top:18px;border-top:1px solid var(--line);font-size:12px;color:var(--faint);display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px}
  footer a{color:var(--muted);text-decoration:none}
  @media(max-width:680px){.grid4{grid-template-columns:1fr 1fr}.stats{grid-template-columns:1fr}.pair{grid-template-columns:1fr;text-align:left}.arrow{text-align:left}}
</style>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
</head>
<body>
<div class="wrap">
  <div style="display:flex;align-items:baseline;gap:12px;flex-wrap:wrap">
    <h1>Internal Link Reallocator</h1>
    <span class="mono tag">GSC EXPORT · RUNS LOCALLY</span>
  </div>
  <p class="lead">Finds your strong pages that could pass internal authority to pages stuck just off the top of page one — so you push struggling pages up using links you already have. Drop a Search Console <strong>Pages</strong> export; everything runs in your browser.</p>
  <div class="proxy"><strong>How it matches:</strong> the standard GSC export doesn't link queries to pages, so this pairs pages by <strong>topical overlap in their URLs</strong> — strong page and target page sharing meaningful path words. It's a fast proxy for spotting opportunities; confirm each pairing makes editorial sense before adding the link. A query×page export (GSC API / Looker Studio) would enable exact query-based matching.</p>

  <div class="drop" id="drop">
    <div style="font-size:14.5px;font-weight:600" id="dropmsg">Drop your GSC Pages export here, or click to choose</div>
    <div class="mono" style="font-size:11.5px;color:var(--faint);margin-top:6px">.xlsx or .csv · reads the Pages tab</div>
    <input type="file" id="file" accept=".xlsx,.csv" style="display:none" />
  </div>
  <div class="err" id="err"></div>

  <div class="card controls" id="controls">
    <div class="grid4">
      <div><label class="f">Donor max position (strong pages)</label><input id="donorpos" type="number" step="0.5" value="3" /></div>
      <div><label class="f">Donor min clicks</label><input id="donorclicks" type="number" value="50" /></div>
      <div><label class="f">Target position band (min–max)</label><input id="targetband" type="text" value="4-12" /></div>
      <div><label class="f">Target min impressions</label><input id="targetimpr" type="number" value="200" /></div>
    </div>
  </div>

  <div class="stats" id="stats"></div>

  <div class="results" id="results">
    <div class="rhead">
      <span class="serif" style="font-size:18px;font-weight:600">Suggested internal links</span>
      <button class="exp" id="csv">Export CSV</button>
    </div>
    <div id="pairs"></div>
    <div id="more" style="padding:6px 4px;font-size:12px;color:var(--faint);text-align:center"></div>
  </div>

  <p class="note" id="note">Donor pages rank strongly and have clicks (authority worth passing); target pages sit in the striking-distance band and could use a lift. Pairs share meaningful words in their URL paths, suggesting topical relevance. Add a contextual in-content link from the donor page to the target, using descriptive anchor text built around the shared topic. This is a prioritisation aid — always sense-check that the link is genuinely relevant and useful to readers before adding it.</p>

  <footer>
    <span>Built by <a href="https://hawkmarketing.io">Hawk Marketing</a> · SEO &amp; AI search consultancy</span>
    <span class="mono">data stays in your browser</span>
  </footer>
</div>

<script>
(function(){
  var STOP={'the':1,'a':1,'an':1,'of':1,'for':1,'in':1,'on':1,'to':1,'and':1,'or':1,'best':1,'new':1,'how':1,'do':1,'what':1,'which':1,'uk':1,'2024':1,'2025':1,'2026':1,'page':1,'index':1,'html':1,'www':1,'com':1,'co':1,'amp':1,'with':1,'your':1,'top':1,'guide':1,'guides':1};
  var rows=[], last=[];
  var $=function(id){return document.getElementById(id);};
  function fmt(n){return Number(n).toLocaleString();}
  function pick(r,names){var keys=Object.keys(r);for(var i=0;i<names.length;i++){var k=keys.find(function(key){return key.trim().toLowerCase()===names[i];});if(k!=null)return r[k];}return undefined;}

  function pathWords(url){
    var s=String(url||'').replace(/^https?:\/\/[^\/]+/i,'').split('?')[0].split('#')[0];
    var parts=s.toLowerCase().split(/[\/\-_.]+/);
    var out={};
    parts.forEach(function(w){
      w=w.replace(/[^a-z0-9]/g,'');
      if(w.length>2 && !STOP[w]){
        var s2=w.length>3 && w.charAt(w.length-1)==='s'? w.slice(0,-1):w; // crude plural fold
        out[s2]=1;
      }
    });
    return out;
  }
  function shortPath(url){var s=String(url||'').replace(/^https?:\/\/[^\/]+/i,'');return s||'/';}

  function showErr(m){$('err').textContent=m;$('err').style.display='block';}

  function handleFile(file){
    $('err').style.display='none';
    var reader=new FileReader();
    reader.onload=function(e){
      try{
        var wb=XLSX.read(new Uint8Array(e.target.result),{type:'array'});
        var sn=wb.SheetNames.find(function(s){return s.toLowerCase().indexOf('page')>-1;})||wb.SheetNames[0];
        var raw=XLSX.utils.sheet_to_json(wb.Sheets[sn]);
        var parsed=raw.map(function(r){
          var page=pick(r,['top pages','page','pages']);
          var pos=pick(r,['position','avg. position','average position']);
          var cl=pick(r,['clicks']); var im=pick(r,['impressions']);
          return {page:String(page==null?'':page).trim(),clicks:Number(cl),impressions:Number(im),position:Number(pos)};
        }).filter(function(r){return r.page&&!isNaN(r.position);});
        if(!parsed.length){return showErr("Couldn't find page rows. Use a Search Console export with a Pages tab (page, clicks, impressions, position).");}
        rows=parsed;
        $('dropmsg').textContent='Loaded: '+file.name+' · '+fmt(rows.length)+' pages';
        $('controls').style.display='block';
        compute();
      }catch(err){showErr("Couldn't read that file. Use a GSC export as .xlsx or .csv.");}
    };
    reader.readAsArrayBuffer(file);
  }

  function compute(){
    if(!rows.length)return;
    var donorPos=+$('donorpos').value, donorClicks=+$('donorclicks').value, targetImpr=+$('targetimpr').value;
    var band=($('targetband').value||'4-12').split('-').map(function(x){return parseFloat(x.trim());});
    var tmin=band[0]||4, tmax=band[1]||12;

    var donors=rows.filter(function(r){return r.position<=donorPos && r.clicks>=donorClicks;})
                   .map(function(r){return Object.assign({},r,{words:pathWords(r.page)});});
    var targets=rows.filter(function(r){return r.position>=tmin && r.position<=tmax && r.impressions>=targetImpr;})
                    .map(function(r){return Object.assign({},r,{words:pathWords(r.page)});});

    var pairs=[];
    targets.forEach(function(t){
      donors.forEach(function(d){
        if(d.page===t.page) return;
        var shared=Object.keys(t.words).filter(function(w){return d.words[w];});
        if(shared.length){
          pairs.push({donor:d, target:t, shared:shared, score:d.clicks*shared.length});
        }
      });
    });
    // keep best donor per target (strongest, most overlap), then sort
    var bestByTarget={};
    pairs.forEach(function(p){
      var k=p.target.page;
      if(!bestByTarget[k] || p.score>bestByTarget[k].score) bestByTarget[k]=p;
    });
    var result=Object.keys(bestByTarget).map(function(k){return bestByTarget[k];})
                     .sort(function(a,b){return b.score-a.score;});
    last=result;

    $('stats').style.display='grid';
    $('stats').innerHTML=
      card('Link suggestions',fmt(result.length),'donor → target pairs','var(--ink)')+
      card('Donor pages available',fmt(donors.length),'strong, authority to pass','var(--forest)')+
      card('Targets needing a push',fmt(targets.length),'in striking-distance band','var(--accent)');

    var box=$('pairs'); box.innerHTML='';
    result.slice(0,60).forEach(function(p){
      var el=document.createElement('div'); el.className='pair';
      el.innerHTML=
        '<div class="node donor"><div class="lab">Link from (donor)</div><div class="url">'+shortPath(p.donor.page)+'</div><div class="meta">pos '+p.donor.position.toFixed(1)+' · '+fmt(p.donor.clicks)+' clicks</div></div>'+
        '<div class="arrow"><div class="big">→</div><div class="topic">shared: <b>'+p.shared.slice(0,3).join(', ')+'</b></div></div>'+
        '<div class="node target"><div class="lab">Link to (target)</div><div class="url">'+shortPath(p.target.page)+'</div><div class="meta">pos '+p.target.position.toFixed(1)+' · '+fmt(p.target.impressions)+' impr</div></div>';
      box.appendChild(el);
    });
    $('more').textContent=result.length>60?('Showing top 60 of '+fmt(result.length)+' — export CSV for the full list'):'';
    $('results').style.display='block'; $('note').style.display='block';
  }
  function card(l,v,s,c){return '<div class="stat"><div class="l">'+l+'</div><div class="v" style="color:'+c+'">'+v+'</div><div class="s">'+s+'</div></div>';}

  $('drop').addEventListener('click',function(){$('file').click();});
  $('file').addEventListener('change',function(e){if(e.target.files[0])handleFile(e.target.files[0]);});
  ['donorpos','donorclicks','targetband','targetimpr'].forEach(function(id){$(id).addEventListener('input',compute);});
  $('drop').addEventListener('dragover',function(e){e.preventDefault();$('drop').classList.add('drag');});
  $('drop').addEventListener('dragleave',function(){$('drop').classList.remove('drag');});
  $('drop').addEventListener('drop',function(e){e.preventDefault();$('drop').classList.remove('drag');if(e.dataTransfer.files[0])handleFile(e.dataTransfer.files[0]);});
  $('csv').addEventListener('click',function(){
    if(!last.length)return;
    var head=['donor_page','donor_position','donor_clicks','target_page','target_position','target_impressions','shared_topic_words'];
    var lines=[head.join(',')].concat(last.map(function(p){
      return ['"'+p.donor.page.replace(/"/g,'""')+'"',p.donor.position.toFixed(1),p.donor.clicks,'"'+p.target.page.replace(/"/g,'""')+'"',p.target.position.toFixed(1),p.target.impressions,'"'+p.shared.join(' ')+'"'].join(',');
    }));
    var url=URL.createObjectURL(new Blob([lines.join('\n')],{type:'text/csv'}));
    var a=document.createElement('a');a.href=url;a.download='internal-link-reallocator.csv';a.click();URL.revokeObjectURL(url);
  });
})();
</script>
</body>
</html>
